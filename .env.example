# ============================================
# QuickServeIT Deployment Configuration
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Connection String
# Format: postgresql://[username]:[password]@[host]:[port]/[database]
# Example: postgresql://postgres:password@localhost:5432/quickserveit
DATABASE_URL=postgres://user:password@localhost:5432/quickserveit

# ============================================
# NODE CONFIGURATION
# ============================================

# Environment: development, production, test
NODE_ENV=development

# Server Port
# Default: 5000 (used by Replit, Railway, etc.)
PORT=5000

# ============================================
# SESSION & SECURITY
# ============================================

# Session Secret (use a random string)
# Generate: npx crypto-random-string --length=32
SESSION_SECRET=your-random-session-secret-here

# Frontend URL (for CORS configuration)
# Development: http://localhost:5173 (Vite frontend)
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# ============================================
# OPTIONAL: Authentication & External Services
# ============================================

# Google OAuth (if implementing)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (if implementing)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# JWT Secret (if using JWT)
# JWT_SECRET=

# API Keys for external services
# STRIPE_API_KEY=
# SENDGRID_API_KEY=

# ============================================
# DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================

# For Vercel Frontend (in Vercel Dashboard)
# VITE_API_URL=https://your-backend-url.railway.app

# For Railway/Render Backend
# DATABASE_URL=postgresql://...
# NODE_ENV=production
# SESSION_SECRET=<generated-secret>
# PORT=5000
